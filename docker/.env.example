# Orbiter v0.1 — environment template.
#
# Copy this file to '.env' (same directory) and fill in real values:
#   cp .env.example .env
#
# Docker Compose automatically loads '.env' next to docker-compose.yml.
# The actual .env file is gitignored (see .gitignore).

# --- Hardware endpoints ----------------------------------------------------

# IP (or hostname) of the ESP32 controller. The server polls/commands it
# over HTTP. Example: 192.168.1.42
ESP32_IP=

# Full URL of the camera MJPEG/JPEG stream. For Android IP Webcam this is
# typically: http://<phone-ip>:8080/shot.jpg
# Leave blank to configure interactively from the UI.
CAMERA_URL=

# --- Storage ---------------------------------------------------------------

# Inside containers the storage dir is fixed at /data (mounted from
# ./data on the host). If you want to move the host side, edit the volume
# mapping in docker-compose.yml — not this file.
