# Orbiter server config — copy to `server/.env` and fill in your own values.
#
# These override the in-app Machine-config defaults at boot. Leave a line
# blank (or delete it) to configure that endpoint from the UI instead.

# ESP32 firmware host (the 2-axis controller). Leave blank to use mDNS
# auto-discovery (orbiter.local).
ORBITER_ESP_IP=

# Phone / IP-Webcam base URL, e.g. http://192.168.1.51:8080
ORBITER_CAMERA_URL=
